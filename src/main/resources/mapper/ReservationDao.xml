<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cms.cms.dao.ReservationDao">

    <select id="findById" resultType="Reservation">
        SELECT *
        FROM reservation
        WHERE id = #{id}
    </select>

    <insert id="save" parameterType="Reservation" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO reservation (
        user_id,
        resource_id,
        reservation_date,
        start_time,
        end_time,
        status
        ) VALUES (
        #{userId},
        #{resourceId},
        #{reservationDate},
        #{startTime},
        #{endTime},
        #{status}
        )
    </insert>

    <update id="updateStatus">
        UPDATE reservation
        SET status = #{status}
        WHERE id = #{id}
    </update>



</mapper>
